rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		function signedIn() {
			return request.auth != null;
		}

		function uid() {
			return request.auth.uid;
		}

		function isOwner(data) {
			return signedIn() && data.userId == uid();
		}

		function folderRefIsValid() {
			return !request.resource.data.keys().hasAny(['folderId']) ||
				request.resource.data.folderId == null ||
				(
					request.resource.data.folderId is string &&
					exists(/databases/$(database)/documents/folders/$(request.resource.data.folderId)) &&
					get(/databases/$(database)/documents/folders/$(request.resource.data.folderId)).data.userId == uid()
				);
		}

		function validFolderData() {
			return request.resource.data.keys().hasOnly([
				'userId',
				'name',
				'createdAt',
				'updatedAt'
			]) &&
				request.resource.data.userId == uid() &&
				request.resource.data.name is string &&
				request.resource.data.name.size() >= 1 &&
				request.resource.data.name.size() <= 50 &&
				request.resource.data.createdAt is timestamp &&
				request.resource.data.updatedAt is timestamp;
		}

		function validHuntData() {
			return request.resource.data.keys().hasOnly([
				'userId',
				'pokemonId',
				'pokemonName',
				'nationalId',
				'shinySpriteUrl',
				'method',
				'encounters',
				'status',
				'startedAt',
				'completedAt',
				'durationMinutes',
				'isAlpha',
				'isPaused',
				'pausedAt',
				'totalPausedMinutes',
				'notes',
				'folderId'
			]) &&
				request.resource.data.userId == uid() &&
				request.resource.data.pokemonId is int &&
				request.resource.data.pokemonName is string &&
				request.resource.data.pokemonName.size() > 0 &&
				request.resource.data.nationalId is int &&
				request.resource.data.shinySpriteUrl is string &&
				request.resource.data.method is string &&
				request.resource.data.encounters is int &&
				request.resource.data.encounters >= 0 &&
				request.resource.data.status in ['active', 'completed', 'abandoned'] &&
				request.resource.data.startedAt is timestamp &&
				(!request.resource.data.keys().hasAny(['completedAt']) || request.resource.data.completedAt == null || request.resource.data.completedAt is timestamp) &&
				(!request.resource.data.keys().hasAny(['durationMinutes']) || (request.resource.data.durationMinutes is int && request.resource.data.durationMinutes >= 0)) &&
				(!request.resource.data.keys().hasAny(['isAlpha']) || request.resource.data.isAlpha is bool) &&
				(!request.resource.data.keys().hasAny(['isPaused']) || request.resource.data.isPaused is bool) &&
				(!request.resource.data.keys().hasAny(['pausedAt']) || request.resource.data.pausedAt == null || request.resource.data.pausedAt is timestamp) &&
				(!request.resource.data.keys().hasAny(['totalPausedMinutes']) || (request.resource.data.totalPausedMinutes is int && request.resource.data.totalPausedMinutes >= 0)) &&
				(!request.resource.data.keys().hasAny(['notes']) || request.resource.data.notes is string) &&
				folderRefIsValid();
		}

		function validShinyData() {
			return request.resource.data.keys().hasOnly([
				'userId',
				'pokemonId',
				'pokemonName',
				'nationalId',
				'shinySpriteUrl',
				'method',
				'encounters',
				'caughtAt',
				'durationMinutes',
				'isAlpha'
			]) &&
				request.resource.data.userId == uid() &&
				request.resource.data.pokemonId is int &&
				request.resource.data.pokemonName is string &&
				request.resource.data.pokemonName.size() > 0 &&
				request.resource.data.nationalId is int &&
				request.resource.data.shinySpriteUrl is string &&
				request.resource.data.method is string &&
				request.resource.data.encounters is int &&
				request.resource.data.encounters >= 0 &&
				request.resource.data.caughtAt is timestamp &&
				request.resource.data.durationMinutes is int &&
				request.resource.data.durationMinutes >= 0 &&
				request.resource.data.isAlpha is bool;
		}

		match /folders/{folderId} {
			allow read: if isOwner(resource.data);
			allow create: if signedIn() && validFolderData();
			allow update: if isOwner(resource.data) &&
				request.resource.data.userId == resource.data.userId &&
				validFolderData();
			allow delete: if isOwner(resource.data);
		}

		match /hunts/{huntId} {
			allow read: if isOwner(resource.data);
			allow create: if signedIn() && validHuntData();
			allow update: if isOwner(resource.data) &&
				request.resource.data.userId == resource.data.userId &&
				validHuntData();
			allow delete: if isOwner(resource.data);
		}

		match /shinies/{shinyId} {
			allow read: if isOwner(resource.data);
			allow create: if signedIn() && validShinyData();
			allow update: if isOwner(resource.data) &&
				request.resource.data.userId == resource.data.userId &&
				validShinyData();
			allow delete: if isOwner(resource.data);
		}

		match /{document=**} {
			allow read, write: if false;
		}
	}
}
